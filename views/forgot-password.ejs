<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Forgot password — Daily Dashboard</title>
  <link rel="stylesheet" href="/style.css" />
  <%- include('partials/head-prefs') %>
</head>

<body class="auth-page">
  <header class="header header--auth">
    <%- include('partials/site-header') %>
  </header>

  <main class="auth-main">
    <section class="panel auth-card">
      <h2>Forgot password</h2>
      <p class="auth-lead">Enter your account email. We will send a temporary password you can use to sign in, then change when you are ready.</p>
      <% if (!mailConfigured) { %>
        <p class="auth-note" role="status">Password reset email is not available on this server yet.</p>
      <% } %>
      <% if (errors && errors.length) { %>
        <ul class="auth-errors" role="alert">
          <% errors.forEach(function (e) { %>
            <li><%= e %></li>
          <% }); %>
        </ul>
      <% } %>
      <% if (success) { %>
        <p class="auth-success" role="status"><%= success %></p>
      <% } %>
      <% if (!success) { %>
        <form method="post" action="/auth/forgot-password" class="auth-form">
          <label class="auth-label" for="forgot-email">Email</label>
          <input id="forgot-email" class="auth-input" type="email" name="email" autocomplete="email"
            value="<%= formEmail %>" required maxlength="254" <%= mailConfigured ? '' : 'disabled' %> />

          <button type="submit" <%= mailConfigured ? '' : 'disabled' %>>Email temporary password</button>
        </form>
      <% } %>
      <p class="auth-foot"><a class="link" href="/login">Back to sign in</a></p>
    </section>
  </main>
</body>

</html>
