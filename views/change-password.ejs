<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Change password — Manager Daily</title>
  <link rel="stylesheet" href="/style.css" />
</head>

<body class="auth-page">
  <header class="header header--auth">
    <%- include('partials/site-header') %>
  </header>

  <main class="auth-main">
    <section class="panel auth-card">
      <h2>Change password</h2>
      <p class="auth-lead">Use your current password (or the temporary one from email), then pick a new password.</p>
      <% if (errors && errors.length) { %>
        <ul class="auth-errors" role="alert">
          <% errors.forEach(function (e) { %>
            <li><%= e %></li>
          <% }); %>
        </ul>
      <% } %>
      <% if (success) { %>
        <p class="auth-success" role="status"><%= success %></p>
      <% } %>
      <form method="post" action="/auth/change-password" class="auth-form">
        <label class="auth-label" for="current-password">Current password</label>
        <input id="current-password" class="auth-input" type="password" name="currentPassword"
          autocomplete="current-password" required />

        <label class="auth-label" for="new-password">New password</label>
        <input id="new-password" class="auth-input" type="password" name="newPassword" autocomplete="new-password"
          required minlength="8" maxlength="128" />

        <label class="auth-label" for="confirm-password">Confirm new password</label>
        <input id="confirm-password" class="auth-input" type="password" name="confirmPassword"
          autocomplete="new-password" required minlength="8" maxlength="128" />

        <button type="submit">Update password</button>
      </form>
      <p class="auth-foot"><a class="link" href="/">Back to Manager Daily</a></p>
    </section>
  </main>
</body>

</html>
