<dialog id="jira-issue-modal" class="jira-issue-dialog" aria-labelledby="jira-issue-modal-title">
  <div class="jira-issue-card">
    <header class="jira-issue-head">
      <div class="jira-issue-head-meta">
        <span id="jira-issue-modal-key" class="jira-issue-key-badge"></span>
        <span id="jira-issue-modal-type" class="jira-issue-type-badge"></span>
        <span
          id="jira-issue-modal-estimate"
          class="jira-issue-estimate"
          aria-label="Original estimate"
          hidden
        ></span>
      </div>
      <button type="button" class="jira-issue-close" id="jira-issue-modal-close" aria-label="Close issue details">
        ×
      </button>
    </header>
    <h2 id="jira-issue-modal-title" class="jira-issue-title">
      <a id="jira-issue-modal-title-link" href="#" target="_blank" rel="noopener noreferrer"></a>
    </h2>
    <section class="jira-issue-dashboard" aria-label="Issue overview">
      <div class="jira-issue-dashboard-col jira-issue-dashboard-col--facts">
        <dl class="jira-issue-facts jira-issue-facts--dashboard">
          <div class="jira-issue-fact">
            <dt>Status</dt>
            <dd id="jira-issue-modal-status" class="jira-issue-status"></dd>
          </div>
          <div class="jira-issue-fact">
            <dt>Time logged</dt>
            <dd id="jira-issue-modal-time"></dd>
          </div>
          <div class="jira-issue-fact jira-issue-fact--assignee" id="jira-issue-modal-assignee-row" hidden>
            <dt>Assignee</dt>
            <dd id="jira-issue-modal-assignee"></dd>
          </div>
          <div class="jira-issue-fact jira-issue-fact--reporter" id="jira-issue-modal-reporter-row" hidden>
            <dt>Reporter</dt>
            <dd id="jira-issue-modal-reporter"></dd>
          </div>
        </dl>
      </div>
      <div class="jira-issue-dashboard-col jira-issue-dashboard-col--sprint">
        <div id="jira-issue-modal-sprint-widget" class="jira-issue-widget jira-issue-widget--sprint" aria-live="polite"></div>
      </div>
      <div class="jira-issue-dashboard-col jira-issue-dashboard-col--subtasks">
        <div id="jira-issue-modal-subtask-widget" class="jira-issue-widget jira-issue-widget--subtasks" aria-live="polite"></div>
      </div>
      <div class="jira-issue-dashboard-col jira-issue-dashboard-col--staleness">
        <div id="jira-issue-modal-staleness-widget" class="jira-issue-widget jira-issue-widget--staleness" aria-live="polite"></div>
      </div>
    </section>
    <section class="jira-issue-scroll" aria-label="Issue description">
      <div id="jira-issue-modal-description" class="jira-issue-description" aria-live="polite"></div>
    </section>
  </div>
</dialog>
