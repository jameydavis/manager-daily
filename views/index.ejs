<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Manager Daily — <%= selected %>
  </title>
  <link rel="stylesheet" href="/style.css" />
</head>

<body>
  <header class="header">
    <h1>Manager Daily</h1>
    <p class="sub">
      <%= monthLabel %> · <a class="link pill" href="/?date=<%= todayISO %>">Today: <%= todayISO %></a>
    </p>
  </header>

  <main class="layout">
    <section class="panel calendar-panel">
      <h2 class="calendar-title">
        <%= calendarHeading %>
      </h2>
      <div class="cal-nav">
        <% const cur=new Date(selected + 'T12:00:00' ); %>
          <a class="link" href="/?date=<%= prevMonthStart %>">← <%= new Date(cur.getFullYear(), cur.getMonth() - 1,
              1).toLocaleString('en-US', { month: 'short' }) %></a>
          <span class="cal-nav-month">
            <%= monthLabel %>
          </span>
          <a class="link" href="/?date=<%= nextMonthStart %>">
            <%= new Date(cur.getFullYear(), cur.getMonth() + 1, 1).toLocaleString('en-US', { month: 'short' }) %> →
          </a>
      </div>
      <% if (sprintBoardError && jiraConfigured && jiraBoardId) { %>
        <p class="hint error-text">Could not load active sprint for <% if (jiraBoardName) { %><%= jiraBoardName %><% } else { %>board <code><%= jiraBoardId %></code><% } %>: <%=
            sprintBoardError %>
        </p>
        <% } %>
          <% if (sprintStart && sprintEnd) { %>
            <% if (sprintSource !== 'jira') { %>
            <p class="hint">
              <%= sprintStart %> — <%= sprintEnd %> (<code>SPRINT_START</code> / <code>SPRINT_END</code>)
            </p>
            <% } %>
            <% } else if (!sprintBoardError) { %>
              <p class="hint">Set <code>JIRA_BOARD_ID</code> (from your board URL, e.g. <code>…/boards/1577</code>) or
                <code>SPRINT_START</code> / <code>SPRINT_END</code> to shade sprint days.</p>
              <% } %>
                <table class="cal">
                  <thead>
                    <tr>
                      <th>Su</th>
                      <th>Mo</th>
                      <th>Tu</th>
                      <th>We</th>
                      <th>Th</th>
                      <th>Fr</th>
                      <th>Sa</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% weeks.forEach(function (row) { %>
                      <tr>
                        <% row.forEach(function (c) { %>
                          <td
                            data-day="<%= c.day %>"
                            class="cal-cell <%= c.inMonth ? '' : 'muted' %> <%= c.isToday ? 'today' : '' %> <%= c.day === selected ? 'cal-selected' : '' %> <% if (sprintRangeActive && c.inMonth) { %><%= c.inSprint ? 'cal-sprint-day' : 'cal-non-sprint-day' %><% } %>">
                            <a href="/?date=<%= c.day %>">
                              <%= c.label %>
                            </a>
                          </td>
                          <% }); %>
                      </tr>
                      <% }); %>
                  </tbody>
                </table>
    </section>

    <section class="panel tasks-panel">
      <h2>Tasks · <%= selected %>
      </h2>
      <form class="row-form" method="post" action="/tasks">
        <input type="hidden" name="day" value="<%= selected %>" />
        <input type="text" name="title" placeholder="New task" required autocomplete="off" />
        <input type="text" name="notes" placeholder="Notes (optional)" autocomplete="off" />
        <button type="submit">Add</button>
      </form>

      <form class="email-paste-form" method="post" action="/tasks/from-email-paste">
        <input type="hidden" name="day" value="<%= selected %>" />
        <label class="email-paste-label" for="email-paste">Follow up from email</label>
        <textarea id="email-paste" name="pasted" class="email-paste-input" rows="4"
          placeholder="Paste subject, snippet, or key lines from Outlook…" autocomplete="off"></textarea>
        <button type="submit" class="secondary">Add “Follow up from Email” task</button>
      </form>

      <% if (prevDay) { %>
        <form method="post" action="/carry-over" class="carry">
          <input type="hidden" name="day" value="<%= selected %>" />
          <button type="submit" class="secondary">Carry over incomplete from <%= prevDay %></button>
        </form>
        <% } %>

          <ul class="tasks">
            <% if (!tasks.length) { %>
              <li class="empty">No tasks for this day.</li>
              <% } %>
                <% tasks.forEach(function (t) { %>
                  <li class="task <%= t.done ? 'done' : '' %>">
                    <form method="post" action="/tasks/<%= t.id %>/toggle" class="inline">
                      <button type="submit" class="check" aria-label="Toggle done">
                        <%= t.done ? '✓' : '○' %>
                      </button>
                    </form>
                    <div class="task-body">
                      <span class="title">
                        <%= t.title %>
                      </span>
                      <% if (t.notes) { %><span class="notes">
                          <%= t.notes %>
                        </span>
                        <% } %>
                    </div>
                    <form method="post" action="/tasks/<%= t.id %>/delete" class="inline"
                      onsubmit="return confirm('Delete this task?');">
                      <button type="submit" class="danger ghost">Remove</button>
                    </form>
                  </li>
                  <% }); %>
          </ul>
    </section>

    <aside class="panel reports-panel" aria-label="Direct reports">
      <h2>My team</h2>
      <% if (!jiraConfigured) { %>
        <p class="hint">Connect Jira in <code>.env</code> to load avatars and profile links for your direct reports.</p>
        <% } else if (directReportsError) { %>
          <p class="hint error-text">
            <%= directReportsError %>
          </p>
          <% } else { %>
            <ul class="report-list">
              <% directReports.forEach(function (r) { %>
                <li class="report-card">
                  <% if (r.avatarUrl) { %>
                    <img class="report-avatar" src="<%= r.avatarUrl %>" alt="" width="40" height="40" loading="lazy" />
                    <% } else { %>
                      <div class="report-avatar report-avatar--placeholder" aria-hidden="true">
                        <%= (r.displayName || '?' ).charAt(0).toUpperCase() %>
                      </div>
                      <% } %>
                        <div class="report-body">
                          <% if (r.peopleUrl) { %>
                            <a class="report-name link" href="<%= r.peopleUrl %>" target="_blank" rel="noopener">
                              <%= r.displayName %>
                            </a>
                            <% } else { %>
                              <span class="report-name">
                                <%= r.displayName %>
                              </span>
                              <% } %>
                                    <% if (r.hint) { %>
                                      <span class="report-hint">
                                        <%= r.hint %>
                                      </span>
                                      <% } %>
                          <% if (r.assigneeIssuesError) { %>
                            <p class="report-issues-error"><%= r.assigneeIssuesError %></p>
                          <% } else if (r.accountId) { %>
                            <% var hasIP = r.assigneeIssuesInProgress && r.assigneeIssuesInProgress.length; var hasO = r.assigneeIssuesOther && r.assigneeIssuesOther.length; %>
                            <% if (hasIP) { %>
                              <ul class="report-issues" aria-label="In Progress">
                                <% r.assigneeIssuesInProgress.forEach(function (issue) { %>
                                  <li class="report-issue">
                                    <a class="link report-issue-key" href="<%= issue.browseUrl %>" target="_blank" rel="noopener"><%= issue.key %></a>
                                    <span class="report-issue-status"><%= issue.status %></span>
                                    <span class="report-issue-time" title="Time logged (Jira)"><%= issue.timeLoggedLabel %></span>
                                    <span class="report-issue-summary"><%= issue.summary %></span>
                                  </li>
                                <% }); %>
                              </ul>
                            <% } %>
                            <% if (!hasIP && !hasO) { %>
                              <p class="report-issue-empty">No unresolved issues assigned.</p>
                            <% } else if (!hasIP && hasO) { %>
                              <p class="report-issue-empty">No issues In Progress.</p>
                            <% } %>
                            <% if (hasO) { %>
                              <details class="report-other-statuses">
                                <summary class="report-other-statuses-summary" aria-label="Other Statuses, <%= r.assigneeIssuesOther.length %> issues">Other Statuses</summary>
                                <ul class="report-issues report-issues--other" aria-label="Other statuses">
                                  <% r.assigneeIssuesOther.forEach(function (issue) { %>
                                    <li class="report-issue">
                                      <a class="link report-issue-key" href="<%= issue.browseUrl %>" target="_blank" rel="noopener"><%= issue.key %></a>
                                      <span class="report-issue-status"><%= issue.status %></span>
                                      <span class="report-issue-time" title="Time logged (Jira)"><%= issue.timeLoggedLabel %></span>
                                      <span class="report-issue-summary"><%= issue.summary %></span>
                                    </li>
                                  <% }); %>
                                </ul>
                              </details>
                            <% } %>
                          <% } %>
                        </div>
                </li>
                <% }); %>
            </ul>
            <% } %>
              <p class="hint report-foot">Edit names in <code>JIRA_DIRECT_REPORTS</code> in <code>.env</code>. Use
                <code>Name|accountId</code> if Jira finds the wrong person.</p>
    </aside>

    <section class="panel integrations">
      <h2>Jira</h2>
      <% if (!jiraConfigured) { %>
        <p class="hint">Connect <strong>Jira Cloud</strong> with an API token (not a separate “Jira API key”):</p>
        <ol class="setup-steps">
          <li>Create a token: <a class="link" href="https://id.atlassian.com/manage-profile/security/api-tokens"
              target="_blank" rel="noopener">Atlassian API tokens</a>.</li>
          <li>In <code>.env</code> set <code>ATLASSIAN_EMAIL</code>, <code>ATLASSIAN_API_TOKEN</code>, and
            <code>ATLASSIAN_SITE</code> (e.g. <code>https://your-site.atlassian.net</code>, no trailing slash).</li>
          <li>Optional: <code>JIRA_JQL</code> to override the default query (my open issues).</li>
        </ol>
        <% } else if (jiraError) { %>
          <p class="hint error-text">Could not load Jira: <%= jiraError %>
          </p>
          <% } else if (!jiraIssues.length) { %>
            <p class="hint">No issues matched your JQL. Adjust <code>JIRA_JQL</code> in <code>.env</code>.</p>
            <% } else { %>
              <p class="hint">Open issues from your JQL. Add one to <strong>
                  <%= selected %>
                </strong>.</p>
              <ul class="jira-list">
                <% jiraIssues.forEach(function (issue) { %>
                  <li class="jira-row">
                    <div class="jira-meta">
                      <a class="link jira-key" href="<%= issue.browseUrl %>" target="_blank" rel="noopener">
                        <%= issue.key %>
                      </a>
                      <span class="jira-status">
                        <%= issue.status %>
                      </span>
                      <span class="jira-type">
                        <%= issue.issueType %>
                      </span>
                    </div>
                    <div class="jira-summary">
                      <%= issue.summary %>
                    </div>
                    <form method="post" action="/tasks/from-jira" class="jira-add">
                      <input type="hidden" name="day" value="<%= selected %>" />
                      <input type="hidden" name="key" value="<%= issue.key %>" />
                      <input type="hidden" name="summary" value="<%= issue.summary %>" />
                      <button type="submit" class="secondary">Add to day</button>
                    </form>
                  </li>
                  <% }); %>
              </ul>
              <% } %>
    </section>
  </main>

  <aside id="desk-pet" class="desk-pet" aria-label="Desk pet">
    <div id="desk-pet-alive" class="desk-pet-panel desk-pet-panel--alive">
      <div class="desk-pet-header">
        <span class="desk-pet-title">Desk buddy</span>
      </div>
      <div class="desk-pet-stage">
        <div class="desk-pet-creature" id="desk-pet-creature" aria-hidden="true">
          <span class="desk-pet-ear desk-pet-ear--left"></span>
          <span class="desk-pet-ear desk-pet-ear--right"></span>
          <span class="desk-pet-blush desk-pet-blush--left"></span>
          <span class="desk-pet-blush desk-pet-blush--right"></span>
          <span class="desk-pet-face">
            <span class="desk-pet-eye-row">
              <span class="desk-pet-eye"><span class="desk-pet-eye-shine"></span></span>
              <span class="desk-pet-eye"><span class="desk-pet-eye-shine"></span></span>
            </span>
            <span class="desk-pet-mouth"></span>
          </span>
        </div>
      </div>
      <p class="desk-pet-status" id="desk-pet-status" aria-live="polite"></p>
      <div
        class="desk-pet-meter"
        role="progressbar"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-valuenow="72"
        aria-label="How full your desk buddy is"
      >
        <span class="desk-pet-meter-fill" id="desk-pet-meter-fill"></span>
      </div>
      <div class="desk-pet-actions">
        <button type="button" class="secondary" id="desk-pet-feed">Feed</button>
        <button type="button" class="secondary" id="desk-pet-tickle">Tickle</button>
      </div>
    </div>
    <div id="desk-pet-revive-panel" class="desk-pet-panel desk-pet-revive-panel" hidden>
      <p class="desk-pet-revive-title">Your desk buddy nodded off…</p>
      <p class="desk-pet-revive-hint">They went too long without a meal. Wake them with a little care.</p>
      <button type="button" class="desk-pet-revive-btn" id="desk-pet-revive">Revive buddy</button>
    </div>
  </aside>
  <script src="/desk-pet.js" defer></script>
</body>

</html>