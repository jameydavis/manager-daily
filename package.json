{
  "name": "daily-dashboard",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build:client && tsx watch src/index.ts",
    "build": "tsc && npm run build:client",
    "build:client": "tsc -p tsconfig.client.json",
    "start": "node dist/index.js",
    "test": "npm run build:client && vitest run",
    "test:coverage": "npm run build:client && vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.1",
    "imapflow": "^1.3.2",
    "mailparser": "^3.9.8",
    "nodemailer": "^8.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/cookie-parser": "^1.4.10",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.5",
    "supertest": "^7.1.3",
    "tsx": "^4.22.3",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  }
}
