# Server
PORT=3000

# SQLite directory (default: ./data)
# DATA_DIR=/path/to/data

# Optional: highlight sprint range on the calendar (YYYY-MM-DD)
# SPRINT_START=2026-04-14
# SPRINT_END=2026-04-25

# --- Jira Cloud
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
# ATLASSIAN_EMAIL=you@company.com
# ATLASSIAN_API_TOKEN=your_atlassian_api_token
# ATLASSIAN_SITE=https://your-site.atlassian.net

# Scrum board id from URL: .../boards/1577 — used for calendar active sprint (Agile REST)
# JIRA_BOARD_ID=1577

# Optional JQL for the “Jira” panel (default: your unresolved issues)
# JIRA_JQL=assignee = currentUser() AND status != Done ORDER BY updated DESC
# JIRA_MAX_RESULTS=25

# Direct reports: comma/newline list; optional Name|accountId. Built-in default if unset.
# JIRA_DIRECT_REPORTS="Austin Carpenter,Ryan Rose"
