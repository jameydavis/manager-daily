# Server
PORT=3000

# Process timezone (IANA). Default: America/Indiana/Indianapolis (Fort Wayne, IN / Eastern).
# TZ=America/New_York

# SQLite directory (default: ./data)
# DATA_DIR=/path/to/data

# Auth (sessions stored in the same SQLite database as the app)
# SESSION_TTL_SECONDS=2592000
# BCRYPT_ROUNDS=12
# In production, set NODE_ENV=production so session cookies use Secure.
# NODE_ENV=production

# Forgot-password email (SMTP). Required in production for /forgot-password.
# In local dev without SMTP, a temporary password is logged to the server console.
# APP_BASE_URL=http://127.0.0.1:3000
# AUTH_SMTP_HOST=smtp.example.com
# AUTH_SMTP_PORT=587
# AUTH_SMTP_SECURE=false
# AUTH_SMTP_USER=you@example.com
# AUTH_SMTP_PASS=your_smtp_password
# AUTH_MAIL_FROM="Daily Dashboard <noreply@example.com>"

# Optional: highlight sprint range on the calendar (YYYY-MM-DD)
SPRINT_START=2026-03-30
SPRINT_END=2026-05-11

# --- Jira Cloud
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
# ATLASSIAN_EMAIL=you@company.com
# ATLASSIAN_API_TOKEN=your_atlassian_api_token
# ATLASSIAN_SITE=https://your-site.atlassian.net

# Scrum board id from URL: .../boards/1577 — used for calendar active sprint (Agile REST)
# JIRA_BOARD_ID=1577

# Optional JQL for the “Jira” panel (default: your unresolved issues)
# JIRA_JQL=assignee = currentUser() AND status != Done ORDER BY updated DESC
# JIRA_MAX_RESULTS=25

# My team: comma- or newline-separated display names; optional Name|accountId per person
# JIRA_DIRECT_REPORTS="Alex Smith,Jordan Lee"

# Max Jira issues fetched per direct report for assignee lists (1–50, default 20).
# REPORT_ASSIGNEE_MAX_ISSUES=20

# --- Important email (optional IMAP — “Follow up from email” suggestions on the day view)
# All of host, user, pass, and at least one keyword must be set for the feature to run.
# EMAIL_IMAP_HOST=imap.example.com
# EMAIL_IMAP_PORT=993
# TLS: omit or any value except "false" for TLS (default). Use EMAIL_IMAP_SECURE=false only if your host requires a plain connection (unusual).
# EMAIL_IMAP_SECURE=true
# EMAIL_IMAP_USER=you@company.com
# EMAIL_IMAP_PASS=your_app_password_or_mail_password
# Folder to scan (default INBOX)
# EMAIL_IMAP_FOLDER=INBOX
# Comma- or newline-separated phrases; case-insensitive match in subject + body
# (e.g. “urgent,action required” or one keyword per line)
# EMAIL_KEYWORDS=urgent,follow up
# How many recent messages to scan from the end of the folder (5–200, default 60)
# EMAIL_MAX_SCAN=60
